# ─────────────────────────────────────────
#  Rootstock Foundry Deployer Action
#  .gitignore
# ─────────────────────────────────────────

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Foundry build artifacts (not relevant here, but for test sub-projects)
out/
cache/
broadcast/

# Docker

# Node (if tooling is added later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files — NEVER commit secrets
.env
.env.*
!.env.example

# Temporary files
*.tmp
*.log
